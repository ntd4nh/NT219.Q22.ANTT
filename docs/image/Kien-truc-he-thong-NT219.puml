@startuml logical_overview
' §5.1 — Kiến trúc logic
title Kiến trúc logic — Bảo mật API Cloud cho SME (ShopFlow)
left to right direction
skinparam packageStyle rectangle
skinparam shadowing false

package "Clients" as pkg_clients {
  [Web SPA] as lo_Web
  [Mobile App] as lo_Mobile
}

package "Edge (Self-host)" as pkg_edge {
  [Nginx + ModSecurity WAF] as lo_WAF
  [Kong OSS Gateway] as lo_GW
  [Webhook Authorizer] as lo_Auth
}

package "Identity" as pkg_identity {
  [OIDC IdP\n(Keycloak)] as lo_IdP
}

package "Microservices" as pkg_services {
  [User Service] as lo_US
  [Order Service] as lo_OS
  [Billing Service] as lo_BS
}

package "Crypto & Secrets" as pkg_crypto {
  [Vault OSS\n(Transit + KV)] as lo_Vault
}

package "Storage" as pkg_storage {
  database "PostgreSQL" as lo_DB
}

package "Observability" as pkg_observe {
  [Prometheus + Loki + Grafana] as lo_CW
}

package "External" as pkg_external {
  [Payment Provider] as lo_PSP
}

lo_Web --> lo_WAF : HTTPS / TLS 1.3
lo_Mobile --> lo_WAF : HTTPS / TLS 1.3
lo_WAF --> lo_GW
lo_Web --> lo_IdP : OIDC + PKCE
lo_Mobile --> lo_IdP : OIDC + PKCE
lo_GW --> lo_IdP : JWKS cache validate
lo_GW --> lo_US : Bearer JWT
lo_GW --> lo_OS : Bearer JWT
lo_GW --> lo_BS : Bearer JWT
lo_US --> lo_Vault : envelope encrypt
lo_OS --> lo_Vault
lo_BS --> lo_Vault
lo_US --> lo_DB
lo_OS --> lo_DB
lo_BS --> lo_DB
lo_GW --> lo_CW
lo_US --> lo_CW
lo_OS --> lo_CW
lo_BS --> lo_CW
lo_PSP --> lo_GW : HMAC signed webhook
lo_GW --> lo_Auth : invoke authorizer
lo_Auth --> lo_BS : forward if valid

@enduml


