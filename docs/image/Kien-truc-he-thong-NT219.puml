dep_AUTH --> dep_BS : if valid
dep_US --> dep_DB
dep_OS --> dep_DB
dep_BS --> dep_DB
dep_US --> dep_Vault
dep_OS --> dep_Vault
dep_BS --> dep_Vault
dep_GW --> dep_Prom
dep_US --> dep_Prom
dep_OS --> dep_Prom
dep_BS --> dep_Prom
dep_GW --> dep_Loki
dep_US --> dep_Loki
dep_OS --> dep_Loki
dep_BS --> dep_Loki
dep_Grafana --> dep_Prom
dep_Grafana --> dep_Loki

@enduml


@startuml seq_oidc_pkce
' §5.3 — OIDC + PKCE
title Luồng 1 — OIDC Authorization Code + PKCE
autonumber

actor "Client SPA" as seq1_C
participant "OIDC IdP" as seq1_IdP
participant "API Gateway" as seq1_GW
participant "Order Service" as seq1_S

seq1_C -> seq1_C : generate code_verifier\n& code_challenge
seq1_C -> seq1_IdP : Authorize (PKCE)
seq1_IdP --> seq1_C : authorization_code
seq1_C -> seq1_IdP : token exchange\n(+ code_verifier)
seq1_IdP --> seq1_C : access JWT\n+ refresh token
seq1_C -> seq1_GW : API request\nAuthorization: Bearer JWT
seq1_GW -> seq1_GW : verify JWT signature\nexp, aud, iss
seq1_GW -> seq1_S : forward + claims
seq1_S -> seq1_S : AuthZ check\n(owner / tenant)
seq1_S --> seq1_C : response (filtered DTO)

note right of seq1_GW
  Mật mã: PKCE, JWS (RS256/ES256),
  access token TTL ngắn (5–15 phút)
end note

@enduml


@startuml seq_s2s
' §5.4 — Service-to-service
title Luồng 2 — Service-to-service (Client Credentials)
autonumber

participant "Billing Service" as seq2_B
participant "OIDC IdP" as seq2_IdP
participant "Order Service" as seq2_O

seq2_B -> seq2_IdP : client_credentials
seq2_IdP --> seq2_B : short-lived JWT
seq2_B -> seq2_O : internal API\nBearer JWT
seq2_O -> seq2_O : validate scope (m2m)
seq2_O --> seq2_B : result

note right of seq2_IdP
  Client secret lưu trong
  Vault OSS (KV)
end note

@enduml


@startuml seq_webhook_hmac
' §5.5 — Webhook HMAC
title Luồng 3 — Webhook có chữ ký HMAC
autonumber

participant "Payment Provider" as seq3_PSP
participant "API Gateway" as seq3_GW
participant "Webhook Authorizer" as seq3_AUTH
participant "Billing Service" as seq3_B

seq3_PSP -> seq3_PSP : body + timestamp + nonce
seq3_PSP -> seq3_PSP : HMAC-SHA256(secret)
seq3_PSP -> seq3_GW : POST webhook\nSignature header
seq3_GW -> seq3_AUTH : invoke custom authorizer
seq3_AUTH -> seq3_AUTH : check timestamp + nonce window
seq3_AUTH -> seq3_AUTH : recompute HMAC\n(constant-time compare)
seq3_AUTH -> seq3_B : forward if valid
seq3_B -> seq3_B : idempotent process

@enduml


@startuml seq_envelope_encryption
' §5.6 — Envelope encryption
title Luồng 4 — Envelope encryption (at-rest)
left to right direction

rectangle "Order Service" as seq4_Svc
rectangle "App logic" as seq4_App
rectangle "Ciphertext" as seq4_Cipher
rectangle "Vault Transit Key" as seq4_Vault
database "PostgreSQL" as seq4_DB

seq4_Svc --> seq4_App : generate DEK
seq4_App --> seq4_Cipher : AES-256-GCM\nencrypt data
seq4_App --> seq4_Vault : encrypt DEK
seq4_Vault --> seq4_DB : store wrapped DEK
seq4_Cipher --> seq4_DB : store ciphertext

note bottom of seq4_Vault
  DEK per-record hoặc per-tenant
end note

@enduml
