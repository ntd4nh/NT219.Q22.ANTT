{
  "__inputs": [
    {
      "name": "DS_PROMETHEUS",
      "label": "Prometheus",
      "type": "datasource",
      "pluginId": "prometheus"
    }
  ],
  "title": "ShopFlow Security Events",
  "uid": "shopflow-security-v2",
  "schemaVersion": 38,
  "version": 1,
  "refresh": "5s",
  "time": { "from": "now-15m", "to": "now" },
  "panels": [
    {
      "id": 1,
      "type": "stat",
      "title": "D1 — BOLA Blocked",
      "description": "So lan tan cong cross-tenant bi chan",
      "gridPos": { "x": 0, "y": 0, "w": 6, "h": 4 },
      "options": {
        "colorMode": "background",
        "graphMode": "area",
        "textMode": "auto",
        "reduceOptions": { "calcs": ["lastNotNull"] }
      },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "thresholds" },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "red", "value": 1 }
            ]
          },
          "mappings": [],
          "unit": "short"
        }
      },
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
          "expr": "sum(shopflow_bola_blocked_total)",
          "legendFormat": "BOLA Blocked"
        }
      ]
    },
    {
      "id": 2,
      "type": "stat",
      "title": "D2 — Token Replay Blocked",
      "description": "So lan replay token bi chan",
      "gridPos": { "x": 6, "y": 0, "w": 6, "h": 4 },
      "options": {
        "colorMode": "background",
        "graphMode": "area",
        "textMode": "auto",
        "reduceOptions": { "calcs": ["lastNotNull"] }
      },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "thresholds" },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "orange", "value": 1 }
            ]
          },
          "unit": "short"
        }
      },
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
          "expr": "sum(shopflow_token_replay_total)",
          "legendFormat": "Token Replay"
        }
      ]
    },
    {
      "id": 3,
      "type": "stat",
      "title": "D4 — SSRF Blocked",
      "description": "So lan tan cong SSRF bi chan",
      "gridPos": { "x": 12, "y": 0, "w": 6, "h": 4 },
      "options": {
        "colorMode": "background",
        "graphMode": "area",
        "textMode": "auto",
        "reduceOptions": { "calcs": ["lastNotNull"] }
      },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "thresholds" },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "purple", "value": 1 }
            ]
          },
          "unit": "short"
        }
      },
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
          "expr": "sum(shopflow_ssrf_blocked_total)",
          "legendFormat": "SSRF Blocked"
        }
      ]
    },
    {
      "id": 4,
      "type": "stat",
      "title": "Auth Failures",
      "description": "Tong so lan xac thuc that bai",
      "gridPos": { "x": 18, "y": 0, "w": 6, "h": 4 },
      "options": {
        "colorMode": "background",
        "graphMode": "area",
        "textMode": "auto",
        "reduceOptions": { "calcs": ["lastNotNull"] }
      },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "thresholds" },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "red", "value": 1 }
            ]
          },
          "unit": "short"
        }
      },
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
          "expr": "sum(shopflow_auth_failures_total)",
          "legendFormat": "Auth Failures"
        }
      ]
    },
    {
      "id": 5,
      "type": "timeseries",
      "title": "Security Events — Real-time (5s refresh)",
      "description": "Counter tang len khi co tan cong bi chan",
      "gridPos": { "x": 0, "y": 4, "w": 24, "h": 10 },
      "options": {
        "legend": { "displayMode": "list", "placement": "bottom" },
        "tooltip": { "mode": "multi" }
      },
      "fieldConfig": {
        "defaults": {
          "custom": {
            "lineWidth": 2,
            "fillOpacity": 10,
            "showPoints": "always",
            "pointSize": 6
          },
          "unit": "short"
        },
        "overrides": [
          { "matcher": { "id": "byName", "options": "BOLA Blocked" },    "properties": [{ "id": "color", "value": { "fixedColor": "red",    "mode": "fixed" } }] },
          { "matcher": { "id": "byName", "options": "Token Replay" },    "properties": [{ "id": "color", "value": { "fixedColor": "orange", "mode": "fixed" } }] },
          { "matcher": { "id": "byName", "options": "SSRF Blocked" },    "properties": [{ "id": "color", "value": { "fixedColor": "purple", "mode": "fixed" } }] },
          { "matcher": { "id": "byName", "options": "Auth Failures" },   "properties": [{ "id": "color", "value": { "fixedColor": "yellow", "mode": "fixed" } }] }
        ]
      },
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
          "expr": "sum(shopflow_bola_blocked_total)",
          "legendFormat": "BOLA Blocked"
        },
        {
          "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
          "expr": "sum(shopflow_token_replay_total)",
          "legendFormat": "Token Replay"
        },
        {
          "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
          "expr": "sum(shopflow_ssrf_blocked_total)",
          "legendFormat": "SSRF Blocked"
        },
        {
          "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
          "expr": "sum(shopflow_auth_failures_total)",
          "legendFormat": "Auth Failures"
        }
      ]
    },
    {
      "id": 6,
      "type": "logs",
      "title": "Security Audit Logs (Loki)",
      "description": "Log real-time khi co su kien bao mat",
      "gridPos": { "x": 0, "y": 14, "w": 24, "h": 10 },
      "options": {
        "dedupStrategy": "none",
        "showLabels": false,
        "showTime": true,
        "sortOrder": "Descending",
        "wrapLogMessage": true
      },
      "targets": [
        {
          "datasource": { "type": "loki", "uid": "loki" },
          "expr": "{job=\"shopflow\"} |= \"audit\"",
          "legendFormat": ""
        }
      ]
    }
  ]
}
