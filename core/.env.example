# Copy to core/.env after Vault bootstrap (do not commit .env)
# lab | production (production enforces fail-closed via SHOPFLOW_ENV)
SHOPFLOW_ENV=lab

# Runtime services: use VAULT_APP_TOKEN from vault/.vault-app-token (NOT root token)
VAULT_APP_TOKEN=
VAULT_ROOT_TOKEN=
VAULT_REQUIRED=false

# Required when SHOPFLOW_ENV=production
# Redis AUTH: REDIS_PASSWORD bảo vệ cache replay/nonce/rate-limit. Để trống = không auth (chỉ dùng cho lab).
# Khi set, REDIS_URL phải mang cùng password: redis://:<pw>@redis:6379
REDIS_PASSWORD=
REDIS_URL=redis://redis:6379

HMAC_SECRET=lab-hmac-secret-change-me
DB_PASSWORD=shopflow_app
TENANT_RATE_LIMIT_RPM=120

# ── Zero-trust internal TLS ──────────────────────────────────────────────
# Mặc định OFF cho lab single-host. BẬT cho deploy trên nền semi-trust (Azure):
#   VAULT_CONFIG_FILE=config-tls.hcl
#   VAULT_ADDR=https://vault:8200
#   VAULT_LOCAL_ADDR=https://127.0.0.1:8200
#   VAULT_SKIP_VERIFY=true        # self-signed internal CA (NT219-Lab-CA)
#   DB_SSL=require                 # ép TLS giữa service ↔ PostgreSQL
# Chạy core/certs/generate-certs.ps1 trước để sinh vault.crt + server.crt.
VAULT_CONFIG_FILE=config.hcl
VAULT_ADDR=http://vault:8200
VAULT_LOCAL_ADDR=http://127.0.0.1:8200
VAULT_SKIP_VERIFY=
DB_SSL=disable

# Keycloak / Grafana (change in production)
KEYCLOAK_ADMIN=admin
KEYCLOAK_ADMIN_PASSWORD=admin
GF_SECURITY_ADMIN_USER=admin
GF_SECURITY_ADMIN_PASSWORD=admin

# S2S (client_credentials)
KEYCLOAK_AUDIENCE=shopflow-api
KEYCLOAK_M2M_CLIENT_ID=shopflow-s2s
KEYCLOAK_M2M_CLIENT_SECRET=shopflow-s2s-secret-change-in-prod
KEYCLOAK_M2M_SCOPE=shopflow-api
WEBHOOK_INTERNAL_SECRET=lab-webhook-internal-secret-change-me
VAULT_DB_REQUIRED=false
