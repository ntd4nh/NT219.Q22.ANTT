# Copy to core/.env after Vault bootstrap (do not commit .env)
# Runtime services: use VAULT_APP_TOKEN from vault/.vault-app-token (NOT root token)
VAULT_APP_TOKEN=
VAULT_ROOT_TOKEN=
VAULT_REQUIRED=false
HMAC_SECRET=lab-hmac-secret-change-me
HMAC_DISABLED=false
SSRF_DISABLED=false
TENANT_RATE_LIMIT_RPM=120
