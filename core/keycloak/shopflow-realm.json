{
  "realm": "shopflow",
  "enabled": true,
  "sslRequired": "external",
  "registrationAllowed": false,
  "loginWithEmailAllowed": true,
  "duplicateEmailsAllowed": false,
  "resetPasswordAllowed": false,
  "editUsernameAllowed": false,
  "bruteForceProtected": true,
  "failureFactor": 5,
  "maxFailureWaitSeconds": 900,
  "waitIncrementSeconds": 60,
  "passwordPolicy": "length(12) and upperCase(1) and digits(1) and specialChars(1) and notUsername",
  "accessTokenLifespan": 900,
  "ssoSessionIdleTimeout": 1800,
  "ssoSessionMaxLifespan": 36000,
  "roles": {
    "realm": [
      { "name": "buyer" },
      { "name": "seller" },
      { "name": "admin" }
    ]
  },
  "clients": [
    {
      "clientId": "shopflow-spa",
      "name": "ShopFlow SPA",
      "enabled": true,
      "publicClient": true,
      "directAccessGrantsEnabled": false,
      "standardFlowEnabled": true,
      "implicitFlowEnabled": false,
      "protocol": "openid-connect",
      "redirectUris": [
        "http://localhost:5173/callback"
      ],
      "webOrigins": [
        "http://localhost",
        "http://localhost:5173"
      ],
      "attributes": {
        "pkce.code.challenge.method": "S256"
      },
      "protocolMappers": [
        {
          "name": "tenant-id-mapper",
          "protocol": "openid-connect",
          "protocolMapper": "oidc-usermodel-attribute-mapper",
          "consentRequired": false,
          "config": {
            "user.attribute": "tenant_id",
            "claim.name": "tenant_id",
            "jsonType.label": "String",
            "id.token.claim": "true",
            "access.token.claim": "true",
            "userinfo.token.claim": "true"
          }
        }
      ]
    },
    {
      "clientId": "shopflow-s2s",
      "name": "ShopFlow S2S",
      "enabled": true,
      "publicClient": false,
      "secret": "shopflow-s2s-secret-change-in-prod",
      "serviceAccountsEnabled": true,
      "directAccessGrantsEnabled": false,
      "standardFlowEnabled": false,
      "fullScopeAllowed": false,
      "protocol": "openid-connect",
      "defaultClientScopes": [
        "shopflow-api"
      ],
      "optionalClientScopes": [
        "shopflow-api",
        "profile",
        "email",
        "roles"
      ],
      "protocolMappers": [
        {
          "name": "audience-shopflow-api",
          "protocol": "openid-connect",
          "protocolMapper": "oidc-audience-mapper",
          "consentRequired": false,
          "config": {
            "included.client.audience": "shopflow-api",
            "id.token.claim": "false",
            "access.token.claim": "true"
          }
        },
        {
          "name": "hardcoded-scope-shopflow-api",
          "protocol": "openid-connect",
          "protocolMapper": "oidc-hardcoded-claim-mapper",
          "consentRequired": false,
          "config": {
            "claim.name": "scope",
            "claim.value": "shopflow-api",
            "jsonType.label": "String",
            "id.token.claim": "false",
            "access.token.claim": "true",
            "userinfo.token.claim": "false"
          }
        }
      ]
    }
  ],
  "clientScopes": [
    {
      "name": "shopflow-api",
      "protocol": "openid-connect",
      "attributes": {
        "include.in.token.scope": "true",
        "display.on.consent.screen": "false"
      }
    }
  ],
  "users": [
    {
      "username": "tenant-a-user",
      "enabled": true,
      "emailVerified": true,
      "firstName": "Tenant",
      "lastName": "A",
      "email": "tenant-a@shopflow.local",
      "credentials": [
        {
          "type": "password",
          "value": "password123",
          "temporary": true
        }
      ],
      "attributes": {
        "tenant_id": [
          "tenant-a"
        ]
      },
      "realmRoles": [
        "buyer"
      ]
    },
    {
      "username": "tenant-b-user",
      "enabled": true,
      "emailVerified": true,
      "firstName": "Tenant",
      "lastName": "B",
      "email": "tenant-b@shopflow.local",
      "credentials": [
        {
          "type": "password",
          "value": "password123",
          "temporary": true
        }
      ],
      "attributes": {
        "tenant_id": [
          "tenant-b"
        ]
      },
      "realmRoles": [
        "seller"
      ]
    },
    {
      "username": "admin-user",
      "enabled": true,
      "emailVerified": true,
      "firstName": "Admin",
      "lastName": "ShopFlow",
      "email": "admin@shopflow.local",
      "credentials": [
        {
          "type": "password",
          "value": "password123",
          "temporary": true
        }
      ],
      "attributes": {
        "tenant_id": [
          "tenant-a"
        ]
      },
      "realmRoles": [
        "admin"
      ]
    }
  ]
}
